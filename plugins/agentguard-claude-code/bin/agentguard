#!/usr/bin/env bash
# AgentGuard plugin launcher.
#
# Discovers a working `agentguard` entry point without requiring the user to
# activate any particular Python environment before starting Claude Code.
# Resolution order (first match wins):
#
#   1. AGENTGUARD_BIN environment variable, if set and executable
#   2. `agentguard` already on PATH (pipx, system install, active venv)
#   3. `~/AgentGuard/.venv/bin/agentguard` (the canonical dev checkout)
#   4. Any `.venv/bin/agentguard` next to common repo checkouts:
#        - $CLAUDE_PROJECT_ROOT, $PWD
#        - $HOME/AgentGuard, $HOME/agentguard, $HOME/src/AgentGuard
#   5. `python3 -m agentguard` if the module imports successfully
#
# Exits with code 127 and a clear message when nothing works, mirroring
# "command not found" semantics so callers can fail loudly.
set -u

_try_run() {
  # Runs "$@" and returns its exit code. Preserves stdin/stdout/stderr.
  "$@"
}

_is_executable() {
  [ -n "${1:-}" ] && [ -x "$1" ]
}

# 1. Explicit override.
if _is_executable "${AGENTGUARD_BIN:-}"; then
  exec "$AGENTGUARD_BIN" "$@"
fi

# 2. Already on PATH.
if command -v agentguard >/dev/null 2>&1; then
  exec agentguard "$@"
fi

# 3 & 4. Known venv locations.
# IMPORTANT: ~/.local/bin/agentguard must be checked here because
# `uv tool install` (the one installer the bootstrap script uses) places
# the binary there, but many shells — including the environment Claude
# Code inherits on a fresh machine — do not have ~/.local/bin on PATH.
# Without this fallback, the plugin would silently fail to find a freshly
# installed agentguard and report "not found" on every invocation until
# the user manually adjusts PATH.
candidates=(
  "${HOME}/.local/bin/agentguard"
  "${HOME}/AgentGuard/.venv/bin/agentguard"
  "${HOME}/agentguard/.venv/bin/agentguard"
  "${HOME}/src/AgentGuard/.venv/bin/agentguard"
  "${CLAUDE_PROJECT_ROOT:-}/.venv/bin/agentguard"
  "${PWD}/.venv/bin/agentguard"
)
for candidate in "${candidates[@]}"; do
  if _is_executable "$candidate"; then
    exec "$candidate" "$@"
  fi
done

# 5. python3 -m agentguard fallback, trying common pythons.
for py in python3 python; do
  if command -v "$py" >/dev/null 2>&1; then
    if "$py" -c "import agentguard" >/dev/null 2>&1; then
      exec "$py" -m agentguard "$@"
    fi
  fi
done

# 6. Last resort: run the bootstrap and retry once.
bootstrap="$(dirname "$0")/../scripts/ensure-agentguard.sh"
if [ -x "$bootstrap" ] && [ "${AGENTGUARD_BOOTSTRAPPED:-0}" != "1" ]; then
  if AGENTGUARD_BOOTSTRAPPED=1 "$bootstrap"; then
    if command -v agentguard >/dev/null 2>&1; then
      exec agentguard "$@"
    fi
    # uv tool install drops the bin into ~/.local/bin even when that dir
    # is absent from PATH; try that path directly before falling through.
    if _is_executable "${HOME}/.local/bin/agentguard"; then
      exec "${HOME}/.local/bin/agentguard" "$@"
    fi
    for py in python3 python; do
      if command -v "$py" >/dev/null 2>&1 && "$py" -c "import agentguard" >/dev/null 2>&1; then
        exec "$py" -m agentguard "$@"
      fi
    done
  fi
fi

cat >&2 <<'EOF'
agentguard not found.

The plugin tried to install it automatically but did not succeed. You can:
  pipx install "agentguard @ git+https://github.com/betaHi/AgentGuard.git"
  pip install --user "agentguard @ git+https://github.com/betaHi/AgentGuard.git"

Or set AGENTGUARD_BIN to an existing executable:
  export AGENTGUARD_BIN=/path/to/agentguard

See ~/.local/state/agentguard/bootstrap.log for what went wrong.
EOF
exit 127
